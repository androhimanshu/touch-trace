<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="20dp"
        android:background="@color/bg_surface">

        <TextView
            android:id="@+id/btnBrowserBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="←"
            android:textColor="@color/accent_cyan"
            android:textSize="20sp"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GESTURE FILES"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:letterSpacing="0.2"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBrowserSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="loading…"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Clear all -->
        <TextView
            android:id="@+id/btnClearAll"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:gravity="center"
            android:text="CLEAR ALL"
            android:textColor="#FF3D5E"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_danger"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:indeterminateTint="@color/accent_cyan"
        android:visibility="gone" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No gesture files yet.\nGo back and start recording."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="80dp"
        android:lineSpacingMultiplier="1.5"
        android:visibility="gone" />

    <!-- File list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:overScrollMode="never" />

    <!-- Divider above footer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Footer hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center"
        android:text="LONG PRESS TO DELETE A FILE"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        android:letterSpacing="0.15"
        android:fontFamily="monospace"
        android:background="@color/bg_surface" />

</LinearLayout>
